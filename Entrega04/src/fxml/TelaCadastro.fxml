<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaCadastro">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Área de Cadastros Gerais" style="-fx-text-fill: #2c3e50;">
                           <font>
                              <Font name="System Bold" size="22.0" />
                           </font>
                        </Label>
                        <Label text="Gerencie os registros de clientes e a entrada de novos veículos no sistema." textFill="#718096" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#tratarBotaoVoltarMenuPrincipal" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="← Menu Principal" />
               </children>
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
            </HBox>

            <StackPane prefHeight="230.0">
               <children>
                  
                  <HBox fx:id="panelHubBotoes" alignment="CENTER" spacing="50.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;">
                     <children>
                        <Button mnemonicParsing="false" onAction="#exibirFormularioCliente" prefHeight="75.0" prefWidth="280.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="👤 Cadastrar Novo Cliente" />
                        <Button mnemonicParsing="false" onAction="#exibirFormularioVeiculo" prefHeight="75.0" prefWidth="280.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="🚗 Cadastrar Novo Veículo" />
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </HBox>

                  <VBox fx:id="panelFormCliente" managed="false" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;" visible="false">
                     <children>
                        <Label text="Formulário de Cadastro: Cliente" textFill="#2b6cb0">
                           <font>
                              <Font name="System Bold" size="15.0" />
                           </font>
                        </Label>
                        <GridPane hgap="20.0" vgap="12.0">
                          <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" maxWidth="130.0" minWidth="10.0" prefWidth="115.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                            <ColumnConstraints hgrow="SOMETIMES" maxWidth="130.0" minWidth="10.0" prefWidth="100.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                          </columnConstraints>
                          <rowConstraints>
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                          </rowConstraints>
                           <children>
                              <Label text="Nome Completo*:" style="-fx-text-fill: #4a5568;" />
                              <TextField fx:id="txtNome" promptText="Nome do cliente" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="1" />
                              
                              <Label text="CPF*:" style="-fx-text-fill: #4a5568;" GridPane.columnIndex="2" />
                              <TextField fx:id="txtCpf" promptText="Apenas números" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="3" />
                              
                              <Label text="CNH*:" style="-fx-text-fill: #4a5568;" GridPane.rowIndex="1" />
                              <TextField fx:id="txtCnh" promptText="Obrigatório para Test-Drive" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              
                              <Label text="E-mail:" style="-fx-text-fill: #4a5568;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                              <TextField fx:id="txtEmail" promptText="exemplo@email.com" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                              
                              <Label text="Telefone:" style="-fx-text-fill: #4a5568;" GridPane.rowIndex="2" />
                              <TextField fx:id="txtTelefone" promptText="(00) 00000-0000" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                           </children>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#voltarParaHubPrincipal" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568; -fx-background-radius: 6; -fx-cursor: hand;" text="Cancelar" />
                              <Button mnemonicParsing="false" onAction="#tratarBotaoCadastrarCliente" prefHeight="32.0" prefWidth="160.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Confirmar Cadastro" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                     </padding>
                  </VBox>

                  <VBox fx:id="panelFormVeiculo" managed="false" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;" visible="false">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="25.0">
                           <children>
                              <Label text="Formulário de Cadastro: Veículo" textFill="#2f855a">
                                 <font>
                                    <Font name="System Bold" size="15.0" />
                                 </font>
                              </Label>
                              <RadioButton fx:id="radioNovo" mnemonicParsing="false" selected="true" style="-fx-text-fill: #2d3748; -fx-font-weight: bold; -fx-cursor: hand;" text="Novo">
                                 <toggleGroup>
                                    <ToggleGroup fx:id="grupoTipoVeiculo" />
                                 </toggleGroup>
                              </RadioButton>
                              <RadioButton fx:id="radioSeminovo" mnemonicParsing="false" style="-fx-text-fill: #2d3748; -fx-font-weight: bold; -fx-cursor: hand;" text="Seminovo" toggleGroup="$grupoTipoVeiculo" />
                           </children>
                        </HBox>
                        <GridPane hgap="20.0" vgap="12.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" maxWidth="130.0" minWidth="10.0" prefWidth="115.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                              <ColumnConstraints hgrow="SOMETIMES" maxWidth="130.0" minWidth="10.0" prefWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <children>
                              <Label text="N° Chassi*:" style="-fx-text-fill: #4a5568;" />
                              <TextField fx:id="txtChassi" promptText="Código do Chassi" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="1" />
                              
                              <Label text="RENAVAM:" style="-fx-text-fill: #4a5568;" GridPane.columnIndex="2" />
                              <TextField fx:id="txtRenavam" promptText="Opcional no cadastro" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="3" />
                              
                              <Label text="Modelo*:" style="-fx-text-fill: #4a5568;" GridPane.rowIndex="1" />
                              <TextField fx:id="txtModelo" promptText="Ex: Corolla XEI" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              
                              <Label text="Ano Fabricação*:" style="-fx-text-fill: #4a5568;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                              <TextField fx:id="txtAno" promptText="Ex: 2024" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                              
                              <Label text="Preço Base (R$)*:" style="-fx-text-fill: #4a5568;" GridPane.rowIndex="2" />
                              <TextField fx:id="txtPreco" promptText="0.00" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                              
                              <Label text="KM Inicial:" style="-fx-text-fill: #4a5568;" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                              <TextField fx:id="txtKm" disable="true" promptText="Obrigatório para Seminovos" style="-fx-background-radius: 4; -fx-border-color: #cbd5e0; -fx-border-radius: 4;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                           </children>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#voltarParaHubPrincipal" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568; -fx-background-radius: 6; -fx-cursor: hand;" text="Cancelar" />
                              <Button mnemonicParsing="false" onAction="#tratarBotaoCadastrarVeiculo" prefHeight="32.0" prefWidth="160.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Adicionar ao Estoque" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                     </padding>
                  </VBox>
               </children>
            </StackPane>

            <VBox spacing="10.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Registros Recentes do Sistema" style="-fx-text-fill: #2d3748;">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                     <children>
                        
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Últimos Clientes Cadastrados" textFill="#4a5568" />
                              <TableView fx:id="tabelaClientes" prefHeight="200.0" prefWidth="200.0" style="-fx-background-radius: 4; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn fx:id="colClienteNome" prefWidth="170.0" text="Nome" />
                                  <TableColumn fx:id="colClienteCpf" prefWidth="110.0" text="CPF" />
                                  <TableColumn fx:id="colClienteCnh" prefWidth="100.0" text="CNH" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>
                        
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Veículos Cadastrados" textFill="#4a5568" HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="comboFiltroStatus" onAction="#tratarFiltroStatus" prefHeight="25.0" prefWidth="160.0" promptText="Filtrar por Status" style="-fx-background-radius: 4;" />
                                 </children>
                              </HBox>
                              <TableView fx:id="tabelaVeiculos" prefHeight="200.0" prefWidth="200.0" style="-fx-background-radius: 4; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn fx:id="colVeiculoModelo" prefWidth="125.0" text="Modelo" />
                                  <TableColumn fx:id="colVeiculoAno" prefWidth="50.0" text="Ano" />
                                  <TableColumn fx:id="colVeiculoPreco" prefWidth="85.0" text="Preço" />
                                  <TableColumn fx:id="colVeiculoKm" prefWidth="80.0" text="Quilometragem" />
                                  <TableColumn fx:id="colVeiculoStatus" prefWidth="95.0" text="Status" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>
                        
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="0.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
