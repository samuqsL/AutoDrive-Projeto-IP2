<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="550.0" prefWidth="1100.0" spacing="15.0" style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaTestDrive">
   <children>
      
      <VBox alignment="TOP_CENTER" prefWidth="320.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label text="Agendar Test-Drive" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Cliente:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                  <ComboBox fx:id="comboCliente" prefWidth="280.0" promptText="Selecione o Cliente" style="-fx-background-radius: 5;" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Veículo:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                  <ComboBox fx:id="comboVeiculo" prefWidth="280.0" promptText="Selecione o Veículo" style="-fx-background-radius: 5;" />
               </children>
            </VBox>
         
            <VBox spacing="5.0">
               <children>
                  <Label text="Data do Test-Drive:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                  <DatePicker fx:id="datePickerData" prefWidth="280.0" promptText="Selecione a data" style="-fx-background-radius: 5;" />
               </children>
            </VBox>
         
            <VBox spacing="5.0">
               <children>
                  <Label text="Hora (HH:mm):" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                  <TextField fx:id="txtHora" promptText="Ex: 14:30" style="-fx-background-radius: 5;" />
               </children>
            </VBox>
            
            <Button mnemonicParsing="false" onAction="#tratarBotaoAgendar" prefWidth="280.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Confirmar Agendamento">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
            
            <Label fx:id="lblMensagem" alignment="CENTER" prefWidth="280.0" text="" textFill="#e10b0b" wrapText="true">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            
            <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#tratarBotaoVoltar" prefWidth="280.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Voltar ao Menu">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
      
      <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Histórico de Test-Drives">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
               <children>
                  <Label text="De:" textFill="#34495e" style="-fx-font-weight: bold;" />
                  <DatePicker fx:id="dpFiltroInicio" prefWidth="130.0" />
                  <Label text="Até:" textFill="#34495e" style="-fx-font-weight: bold;" />
                  <DatePicker fx:id="dpFiltroFim" prefWidth="130.0" />
                  <Button mnemonicParsing="false" onAction="#acaoFiltrarPorPeriodo" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Filtrar" />
                  <Button mnemonicParsing="false" onAction="#acaoLimparFiltro" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Limpar" />
               </children>
            </HBox>
            
            <TableView fx:id="tabelaTestDrives" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
              <columns>
                <TableColumn fx:id="colID" prefWidth="85.0" text="ID" />
                <TableColumn fx:id="colCPF" prefWidth="110.0" text="CPF" />
                <TableColumn fx:id="colNome" prefWidth="130.0" text="Nome" />
                <TableColumn fx:id="colChassi" prefWidth="110.0" text="Chassi" />
                <TableColumn fx:id="colData" prefWidth="110.0" text="Data Marcada" />
                <TableColumn fx:id="colHora" prefWidth="85.0" text="Hora" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
      
      <VBox alignment="TOP_CENTER" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
         <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
         </padding>
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #c0392b;" text="Cancelar Agendamento" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            
            <VBox spacing="5.0" prefWidth="170.0">
               <children>
                  <Label text="ID do Agendamento:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                  <TextField fx:id="txtIDCancelamento" alignment="CENTER" promptText="Ex: A3B4F2" style="-fx-background-radius: 5;" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </VBox>
            
            <Button mnemonicParsing="false" onAction="#acaoCancelarAgendamento" prefWidth="170.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Cancelar">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</HBox>