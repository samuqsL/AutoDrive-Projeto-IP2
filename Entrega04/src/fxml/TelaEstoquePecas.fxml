<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="550.0" prefWidth="650.0" spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaEstoquePecas">
   <children>
      <Label text="Reposição de Estoque de Peças">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>
      
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Selecionar Peça:" />
            <ComboBox fx:id="cbPecas" prefWidth="350.0" promptText="Clique para ver as peças..." />
         </children>
      </HBox>
      
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Quantidade para Adicionar:" />
            <TextField fx:id="txtQuantidadeReposicao" prefWidth="90.0" promptText="Ex: 10" />
            <Button mnemonicParsing="false" onAction="#adicionarNaLista" text="Adicionar à Lista" />
         </children>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </HBox>
      
      <Label text="Peças incluídas no lote de reposição atual:">
         <font>
            <Font name="System Italic" size="13.0" />
         </font>
      </Label>
      
      <TableView fx:id="tabelaReposicao" prefHeight="220.0" prefWidth="520.0">
        <columns>
          <TableColumn fx:id="colunaNome" prefWidth="380.0" text="Nome da Peça" />
          <TableColumn fx:id="colunaQuantidade" prefWidth="150.0" text="Qtd. Informada" />
        </columns>
         <VBox.margin>
            <Insets left="40.0" right="40.0" />
         </VBox.margin>
      </TableView>
      
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#confirmarReposicaoTotal" prefHeight="45.0" prefWidth="250.0" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-background-color: #2b5797; -fx-text-fill: white;" text="Confirmar Reposição" />
            <Button mnemonicParsing="false" onAction="#voltarAoMenu" prefHeight="45.0" prefWidth="180.0" style="-fx-font-size: 14px;" text="Voltar ao Menu" />
         </children>
         <VBox.margin>
            <Insets top="15.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="25.0" />
   </padding>
</VBox>
