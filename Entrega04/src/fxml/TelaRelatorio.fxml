<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="500.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaRelatorio">
   <children>
      <StackPane prefHeight="400.0" prefWidth="400.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>
            <VBox fx:id="painelMenuRelatorios" alignment="TOP_CENTER" spacing="12.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="MÓDULO DE RELATÓRIOS">
                     <font>
                        <Font size="18.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" top="5.0" />
                     </VBox.margin>
                  </Label>
                  
                  <Button mnemonicParsing="false" onAction="#carregarVendasGerais" prefWidth="280.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Vendas Gerais" />
                  <Button mnemonicParsing="false" onAction="#carregarVendasPorVendedor" prefWidth="280.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Vendas por Vendedor" />
                  <Button mnemonicParsing="false" onAction="#carregarVendasPorPeriodo" prefWidth="280.0" style="-fx-background-color: #a39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Vendas por Período" />
                  <Button mnemonicParsing="false" onAction="#carregarGeralOficina" prefWidth="280.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Geral da Oficina (OS)" />
                  <Button mnemonicParsing="false" onAction="#carregarLucratividade" prefWidth="280.0" style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Lucratividade (Peças/Serviços)" />
                  
                  <VBox alignment="CENTER_LEFT" spacing="5.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Resultado da Consulta / Console:" />
                        <TextArea fx:id="txtAreaConsole" editable="false" prefHeight="220.0" prefWidth="380.0" promptText="Nenhum relatório gerado ainda." style="-fx-font-family: 'Courier New'; -fx-font-size: 12;" VBox.vgrow="ALWAYS" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </VBox>
                  
                  <Button mnemonicParsing="false" onAction="#voltarParaMenu" prefWidth="160.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Voltar ao Menu" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>
