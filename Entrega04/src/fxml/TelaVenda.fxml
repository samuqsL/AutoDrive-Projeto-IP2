<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="550.0" prefWidth="1100.0" spacing="15.0" style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaVenda">
   <children>
      
      <StackPane prefWidth="350.0">
         <children>
            
            <VBox fx:id="painelMenuVendas" alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Área de Vendas">
                     <font>
                        <Font size="20.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>
                  
                  <Button mnemonicParsing="false" onAction="#acaoAbrirFormulario" prefWidth="300.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Realizar Nova Venda">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#botaoVerificarAlertas" prefWidth="300.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Verificar Alertas de Revisão">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
                  
                  <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Label text="Alertas do Sistema:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                        <TextArea fx:id="txtAreaAlertas" editable="false" prefHeight="200.0" prefWidth="300.0" promptText="Nenhum alerta verificado." style="-fx-background-radius: 5; -fx-border-color: #ecf0f1; -fx-border-radius: 5;" wrapText="true" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
                  
                  <Button mnemonicParsing="false" onAction="#acaoSairParaMenuPrincipal" prefWidth="300.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Voltar ao Menu">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
               </children>
            </VBox>

            <VBox fx:id="painelFormulario" alignment="TOP_CENTER" managed="false" spacing="12.0" visible="false" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Efetuar Nova Venda">
                     <font>
                        <Font size="20.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>
                  
                  <VBox spacing="6.0" alignment="CENTER_LEFT">
                     <children>
                        <Label text="Selecione o Cliente:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="comboCliente" prefWidth="310.0" promptText="Selecione o Cliente..." style="-fx-background-radius: 5;" />
                        
                        <Label text="Selecione o Veículo:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="comboVeiculo" prefWidth="310.0" promptText="Selecione o Veículo..." style="-fx-background-radius: 5;" />
                        
                        <Label text="Selecione o Vendedor:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="comboVendedor" prefWidth="310.0" promptText="Selecione o Vendedor..." style="-fx-background-radius: 5;" />
                        
                        <Label text="Valor de Entrada:" textFill="#7f8c8d" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtEntrada" style="-fx-background-radius: 5;" />
                     </children>
                  </VBox>
                  
                  <Label fx:id="lblStatus" alignment="CENTER" maxWidth="300.0" textAlignment="CENTER" wrapText="true">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  
                  <VBox alignment="BOTTOM_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button mnemonicParsing="false" onAction="#botaoConfirmarVenda" prefWidth="310.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Confirmar">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#acaoVoltarMenuVendas" prefWidth="310.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Voltar" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
      
      <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Histórico de Vendas (Consulta Rápida)">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
               <children>
                  <Label text="De:" textFill="#34495e" style="-fx-font-weight: bold;" />
                  <DatePicker fx:id="dpFiltroInicio" prefWidth="130.0" />
                  <Label text="Até:" textFill="#34495e" style="-fx-font-weight: bold;" />
                  <DatePicker fx:id="dpFiltroFim" prefWidth="130.0" />
                  <Button mnemonicParsing="false" onAction="#acaoFiltrarPorPeriodo" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Filtrar" />
                  <Button mnemonicParsing="false" onAction="#acaoLimparFiltro" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Limpar" />
               </children>
            </HBox>
            
            <TableView fx:id="tabelaVendas" style="-fx-background-radius: 5;" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colNumero" prefWidth="100.0" text="Nº Venda" />
                <TableColumn fx:id="colCliente" prefWidth="150.0" text="Cliente" />
                <TableColumn fx:id="colVeiculo" prefWidth="150.0" text="Veículo" />
                <TableColumn fx:id="colTotal" prefWidth="120.0" text="Total (R$)" />
                <TableColumn fx:id="colData" prefWidth="150.0" text="Data/Hora" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
      
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</HBox>