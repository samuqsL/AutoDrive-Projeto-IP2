<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1150.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaOficina">
   
   <top>
      <VBox spacing="5.0" style="-fx-background-color: #2c3e50; -fx-padding: 15px;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label text="AutoDrive - Sistema de Gerenciamento de Oficina" textFill="WHITE">
                     <font>
                        <font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <Button mnemonicParsing="false" onAction="#botaoVoltar" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Voltar ao Menu" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <Label fx:id="lblMensagem" text="Pronto para operar" textFill="#2ecc71">
               <font>
                  <font name="System Italic" size="13.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </top>

   <center>
      <HBox spacing="15.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            
            <VBox minWidth="320.0" prefWidth="350.0" spacing="15.0">
               <children>
                  
                  <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 5px; -fx-background-radius: 5px; -fx-padding: 12px;" VBox.vgrow="ALWAYS">
                     <children>
                        <Label text="Abrir Nova Ordem de Serviço" textFill="#2c3e50">
                           <font>
                              <font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        
                        <Label text="1. Selecione o Cliente na Tabela abaixo:" textFill="#57606f" />
                        
                        <TableView fx:id="tblClientes" prefHeight="220.0" style="-fx-border-color: #f1f2f6;" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colNomeCliente" prefWidth="180.0" text="Nome do Cliente" />
                            <TableColumn fx:id="colCpfCliente" prefWidth="120.0" text="CPF" />
                          </columns>
                        </TableView>
                        
                        <Label text="2. Digite o Chassi do Veículo:" textFill="#57606f" />
                        <TextField fx:id="txtChassi" promptText="Ex: 9BWZZZ372VET612" style="-fx-padding: 8px;" />
                        
                        <Button fx:id="btnAbrirOS" maxWidth="Infinity" mnemonicParsing="false" onAction="#botaoAbrirOS" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px; -fx-cursor: hand;" text="Abrir Ordem de Serviço" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 5px; -fx-background-radius: 5px; -fx-padding: 12px;">
                     <children>
                        <Label text="Finalizar Ordem de Serviço" textFill="#2c3e50">
                           <font>
                              <font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        
                        <Label text="Selecione a OS em manutenção:" textFill="#57606f" />
                        <ComboBox fx:id="cbOsManutencao" maxWidth="Infinity" promptText="Selecione a OS para finalizar..." style="-fx-padding: 5px;" />
                        
                        <Button fx:id="btnFinalizarOS" maxWidth="Infinity" mnemonicParsing="false" onAction="#botaoFinalizarServico" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px; -fx-cursor: hand;" text="Finalizar e Liberar Veículo" />
                     </children>
                  </VBox>
                  
               </children>
            </VBox>
            
            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 5px; -fx-background-radius: 5px; -fx-padding: 10px;">
                     <children>
                        <Label text="Filtrar Painéis por Data:" textFill="#2c3e50">
                           <font>
                              <font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <DatePicker fx:id="dpFiltroData" promptText="Selecione uma data..." style="-fx-padding: 2px;" />
                        <Button mnemonicParsing="false" onAction="#botaoFiltrar" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;" text="Filtrar" />
                        <Button mnemonicParsing="false" onAction="#botaoLimparFiltro" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-border-color: #7f8c8d; -fx-border-radius: 3px; -fx-cursor: hand;" text="Limpar" />
                     </children>
                  </HBox>
                  
                  <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                     <children>
                        
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="BASELINE_LEFT" spacing="10.0">
                                 <children>
                                    <Label text="Fila de Espera e Manutencao Ativa" textFill="#2c3e50">
                                       <font>
                                          <font name="System Bold" size="13.0" />
                                       </font>
                                    </Label>
                                    <Label text="(Manutenções no topo | Fila ordenada por antiguidade)" textFill="#7f8c8d">
                                       <font>
                                          <font name="System Italic" size="11.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </HBox>
                              <TableView fx:id="tblFilaManutencao" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn fx:id="colNumeroOSFila" prefWidth="75.0" text="Nº OS" />
                                  <TableColumn fx:id="colClienteOSFila" prefWidth="180.0" text="Ordem / Nome do Cliente" />
                                  <TableColumn fx:id="colVeiculoChassiFila" prefWidth="110.0" text="Chassi Veículo" />
                                  <TableColumn fx:id="colDataFila" prefWidth="95.0" text="Data Abertura" />
                                  <TableColumn fx:id="colStatusFila" prefWidth="110.0" text="Status" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>
                        
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Histórico de OS Finalizadas" textFill="#2c3e50">
                                 <font>
                                    <font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                              <TableView fx:id="tblHistorico" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn fx:id="colNumeroOSHist" prefWidth="75.0" text="Nº OS" />
                                  <TableColumn fx:id="colClienteOSHist" prefWidth="180.0" text="Ordem / Nome do Cliente" />
                                  <TableColumn fx:id="colVeiculoChassiHist" prefWidth="110.0" text="Chassi Veículo" />
                                  <TableColumn fx:id="colDataHist" prefWidth="95.0" text="Data Abertura" />
                                  <TableColumn fx:id="colStatusHist" prefWidth="110.0" text="Status" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>
                        
                     </children>
                  </HBox>
                  
               </children>
            </VBox>
            
         </children>
      </HBox>
   </center>
</BorderPane>
