<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.ufrpe.autodrive.gui.TelaVenda">
   <children>
      <HBox spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            
            <StackPane prefWidth="330.0">
               <children>
                  <VBox fx:id="painelMenuVendas" alignment="TOP_CENTER" spacing="10.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Área de Vendas" />
                        <Button mnemonicParsing="false" onAction="#acaoAbrirFormulario" prefWidth="250.0" text="Realizar Nova Venda" />
                        <Button mnemonicParsing="false" onAction="#botaoVerificarAlertas" prefWidth="250.0" text="Verificar Alertas de Revisão" />
                        <VBox alignment="CENTER_LEFT" spacing="5.0" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Alertas do Sistema:" />
                              <TextArea fx:id="txtAreaAlertas" editable="false" prefHeight="200.0" prefWidth="320.0" promptText="Nenhum alerta verificado." VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#acaoSairParaMenuPrincipal" prefWidth="150.0" text="Sair" />
                     </children>
                  </VBox>
                  
                  <VBox fx:id="painelFormulario" alignment="TOP_CENTER" managed="false" spacing="8.0" visible="false">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Efetuar Nova Venda" />
                        <VBox alignment="CENTER_LEFT" maxWidth="280.0" spacing="2.0">
                           <children>
                              <Label text="Selecione o Cliente:" />
                              <ComboBox fx:id="comboCliente" prefWidth="280.0" promptText="Selecione o Cliente..." />
                              <Label text="Selecione o Veículo:" />
                              <ComboBox fx:id="comboVeiculo" prefWidth="280.0" promptText="Selecione o Veículo..." />
                              <Label text="Selecione o Vendedor:" />
                              <ComboBox fx:id="comboVendedor" prefWidth="280.0" promptText="Selecione o Vendedor..." />
                              <Label text="Valor de Entrada:" />
                              <TextField fx:id="txtEntrada" />
                           </children>
                        </VBox>
                        <Label fx:id="lblStatus" alignment="CENTER" maxWidth="300.0" wrapText="true" />
                        <VBox alignment="CENTER" spacing="5.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#botaoConfirmarVenda" prefWidth="180.0" text="Confirmar" />
                              <Button mnemonicParsing="false" onAction="#acaoVoltarMenuVendas" prefWidth="180.0" text="Voltar" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </StackPane>
            
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Histórico de Vendas (Consulta Rápida)" />
                  
                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <children>
                        <Label text="De:" />
                        <DatePicker fx:id="dpFiltroInicio" prefWidth="120.0" />
                        <Label text="Até:" />
                        <DatePicker fx:id="dpFiltroFim" prefWidth="120.0" />
                        <Button mnemonicParsing="false" onAction="#acaoFiltrarPorPeriodo" text="Filtrar" />
                        <Button mnemonicParsing="false" onAction="#acaoLimparFiltro" text="Limpar" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="tabelaVendas" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colNumero" prefWidth="65.0" text="Nº Venda" />
                      <TableColumn fx:id="colCliente" prefWidth="95.0" text="Cliente" />
                      <TableColumn fx:id="colVeiculo" prefWidth="105.0" text="Veículo" />
                      <TableColumn fx:id="colTotal" prefWidth="80.0" text="Total (R$)" />
                      <TableColumn fx:id="colData" prefWidth="110.0" text="Data/Hora" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            
         </children>
      </HBox>
   </children>
</AnchorPane>
